# System-Only Mode Configuration
# Copy this to .env and update the values

# System Security
REACT_APP_SYSTEM_SECRET=your-secure-system-secret-key-here
SYSTEM_SECRET=your-secure-system-secret-key-here

# System Operation Mode
REACT_APP_SYSTEM_ONLY_MODE=true
REACT_APP_BLOCK_USER_INPUT=true

# API Configuration
REACT_APP_API_BASE_URL=http://localhost:5000
REACT_APP_SYSTEM_API_AUTH=system-only

# Data Collection Settings
REACT_APP_AUTO_DATA_COLLECTION=true
REACT_APP_DISABLE_FORMS=true
REACT_APP_AUTOMATED_TRACKING=true

# Backend Configuration
MONGODB_URI=mongodb://localhost:27017/
DATABASE_NAME=eduplanner
FLASK_DEBUG=False
FLASK_ENV=production

# CORS Settings (System-only endpoints)
CORS_ORIGINS=http://localhost:3000

# File Upload (Disabled in system-only mode)
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=0

# Gemini API (For system analysis only)
GEMINI_API_KEY=your-gemini-api-key

# Logging
LOG_LEVEL=INFO
SYSTEM_AUDIT_LOG=true
