{
  "version": 2,
  "name": "edumaster-frontend",
  "buildCommand": "cd FrontEnd/ai-study-planner && npm run build",
  "outputDirectory": "FrontEnd/ai-study-planner/build",
  "installCommand": "cd FrontEnd/ai-study-planner && npm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}