# Environment Variables for EduMaster Backend
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file with real values to version control!

# Gemini AI API Key (Get from: https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/
DATABASE_NAME=eduplanner

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your_very_secure_secret_key_change_this_in_production

# Upload Configuration
MAX_CONTENT_LENGTH=16777216
UPLOAD_FOLDER=uploaded_slides

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,https://your-vercel-domain.vercel.app

# Email Configuration
# Replace these with your actual email settings:
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SENDER_EMAIL=your_email@gmail.com